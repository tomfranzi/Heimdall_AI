<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Heimdall_AI.ViewModels"
             xmlns:models="clr-namespace:Heimdall_AI.Models"
             x:Class="Heimdall_AI.Views.AlertesPage"
             Title="Alertes"
             BackgroundColor="#0F172A">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" 
                 Command="{Binding LoadAlertesCommand}"
                 RefreshColor="#3B82F6">

        <CollectionView ItemsSource="{Binding ListeAlertes}"
                        SelectionMode="None"
                        Margin="15">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Alertes">
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="#1E293B"
                            Margin="0,0,0,12"
                            Padding="15">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AlertesViewModels}}, Path=AlerteTappedCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="5">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Titre}" TextColor="White" FontAttributes="Bold" FontSize="16" />
                            <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 8" BackgroundColor="{Binding CouleurBadge}" Padding="8,4" HorizontalOptions="End">
                                <Label Text="{Binding Niveau}" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                            </Border>
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Description}" TextColor="#94A3B8" FontSize="14" LineBreakMode="WordWrap" />
                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DateCreation, StringFormat='{0:dd/MM/yyyy HH:mm}'}" TextColor="#64748B" FontSize="12" Margin="0,5,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="✅" FontSize="40" HorizontalOptions="Center" />
                    <Label Text="Aucune alerte pour le moment" TextColor="#94A3B8" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </RefreshView>
</ContentPage>