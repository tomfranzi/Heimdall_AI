<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Heimdall_AI.ViewModels"
             x:Class="Heimdall_AI.Views.SupervisionPage"
             BackgroundColor="#020817"
             Shell.NavBarIsVisible="False">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshDonneesCommand}" RefreshColor="#3B82F6">
        <ScrollView>
            <VerticalStackLayout Padding="20,15,20,30" Spacing="30">

                <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,10">
                    <Path Grid.Column="0" Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" Fill="#94A3B8" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" Margin="0,0,15,0"/>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                        <Label Text="Heimdall AI" TextColor="#3B82F6" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" />
                        <Label Text="Supervision" TextColor="White" FontSize="22" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Border Grid.Column="2" BackgroundColor="#0F172A" StrokeShape="RoundRectangle 20" StrokeThickness="1" Stroke="#1E293B" WidthRequest="40" HeightRequest="40" Margin="0,0,10,0">
                        <Path Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" Fill="#94A3B8" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="3" BackgroundColor="#1E293B" StrokeShape="RoundRectangle 20" StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" Fill="#64748B" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <Grid HeightRequest="340" WidthRequest="340" HorizontalOptions="Center" VerticalOptions="Center">

                    <Ellipse WidthRequest="340" HeightRequest="340" HorizontalOptions="Center" VerticalOptions="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1E3A8A" Offset="0.0" />
                                <GradientStop Color="#020817" Offset="1.0" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Ellipse Stroke="#1E293B" StrokeThickness="1" WidthRequest="300" HeightRequest="300" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Ellipse Stroke="#334155" StrokeThickness="1" WidthRequest="200" HeightRequest="200" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.8"/>
                    <Ellipse Stroke="#475569" StrokeThickness="1" WidthRequest="100" HeightRequest="100" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.6"/>

                    <BoxView WidthRequest="1" HeightRequest="320" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.3">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <BoxView HeightRequest="1" WidthRequest="320" VerticalOptions="Center" HorizontalOptions="Center" Opacity="0.3">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <Border StrokeShape="RoundRectangle 150" WidthRequest="300" HeightRequest="300" HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="Transparent" StrokeThickness="0" Padding="0">
                        <Grid x:Name="RadarSweep" WidthRequest="300" HeightRequest="300">
                            <Border WidthRequest="150" HeightRequest="150" HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="Transparent" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                        <GradientStop Color="#903B82F6" Offset="0.0" />
                                        <GradientStop Color="Transparent" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <BoxView Color="#3B82F6" HeightRequest="2" WidthRequest="150" HorizontalOptions="End" VerticalOptions="Center">
                                <BoxView.Shadow>
                                    <Shadow Brush="#3B82F6" Radius="8" Opacity="1"/>
                                </BoxView.Shadow>
                            </BoxView>
                        </Grid>
                    </Border>

                    <Ellipse Fill="#3B82F6" WidthRequest="12" HeightRequest="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Ellipse.Shadow>
                            <Shadow Brush="#3B82F6" Radius="15" Opacity="0.8" />
                        </Ellipse.Shadow>
                    </Ellipse>
                    <Ellipse Stroke="#3B82F6" StrokeThickness="1.5" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.6" />

                    <Ellipse x:Name="Capteur1" Fill="#10B981" WidthRequest="10" HeightRequest="10" HorizontalOptions="Center" VerticalOptions="Center" TranslationX="60" TranslationY="60" Opacity="0">
                        <Ellipse.Shadow>
                            <Shadow Brush="#10B981" Radius="10" Opacity="0.8"/>
                        </Ellipse.Shadow>
                    </Ellipse>

                    <Ellipse x:Name="Capteur2" Fill="#10B981" WidthRequest="10" HeightRequest="10" HorizontalOptions="Center" VerticalOptions="Center" TranslationX="-80" TranslationY="40" Opacity="0">
                        <Ellipse.Shadow>
                            <Shadow Brush="#10B981" Radius="10" Opacity="0.8"/>
                        </Ellipse.Shadow>
                    </Ellipse>

                    <Grid x:Name="Capteur3" HorizontalOptions="Center" VerticalOptions="Center" TranslationX="-70" TranslationY="-50" Opacity="0">
                        <Ellipse Fill="#EF4444" WidthRequest="14" HeightRequest="14" HorizontalOptions="Center" VerticalOptions="Center">
                            <Ellipse.Shadow>
                                <Shadow Brush="#EF4444" Radius="15" Opacity="0.9"/>
                            </Ellipse.Shadow>
                        </Ellipse>
                        <Ellipse Stroke="#EF4444" StrokeThickness="2" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.4"/>
                    </Grid>

                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#1E293B" BackgroundColor="#0F172A" Padding="15">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.3"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="STATUT RÉSEAU" TextColor="#64748B" FontSize="11" FontAttributes="Bold" />
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Ellipse Fill="{Binding CouleurStatut}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center">
                                    <Ellipse.Shadow>
                                        <Shadow Brush="{Binding CouleurStatut}" Radius="5" Opacity="0.8"/>
                                    </Ellipse.Shadow>
                                </Ellipse>
                                <Label Text="{Binding StatutSysteme}" TextColor="#F8FAFC" FontSize="16" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <Label Text="Signal Optimal" TextColor="#10B981" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#1E293B" BackgroundColor="#0F172A" Padding="15">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.3"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="CAPTEURS ACTIFS" TextColor="#64748B" FontSize="11" FontAttributes="Bold" />
                            <HorizontalStackLayout Spacing="4" VerticalOptions="End">
                                <Label Text="{Binding CapteursActifs}" TextColor="#F8FAFC" FontSize="20" FontAttributes="Bold" />
                                <Label Text="{Binding CapteursTotal, StringFormat='/ {0}'}" TextColor="#475569" FontSize="14" Margin="0,0,0,2" VerticalOptions="End" />
                            </HorizontalStackLayout>
                            <ProgressBar Progress="{Binding ProgressionCapteurs}" ProgressColor="#3B82F6" HeightRequest="4" BackgroundColor="#1E293B" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#1E293B" BackgroundColor="#0F172A" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.3"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="DERNIÈRE ALERTE" TextColor="#64748B" FontSize="11" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="1" Text="il y a 2 min" TextColor="#475569" FontSize="12" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Intrusion détectée au Secteur Est" TextColor="#FCA5A5" FontSize="14" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="LAT 45.9 • LON 6.1" TextColor="#3B82F6" FontSize="12" FontAttributes="Bold" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>