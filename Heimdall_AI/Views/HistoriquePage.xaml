<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Heimdall_AI.ViewModels"
             xmlns:models="clr-namespace:Heimdall_AI.Models"
             x:Class="Heimdall_AI.Views.HistoriquePage"
             BackgroundColor="#020817"
             Shell.NavBarIsVisible="False">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RafraichirCommand}"
                 RefreshColor="#3B82F6">

        <VerticalStackLayout Padding="16,18,16,20" Spacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#0B2A5E" Padding="11" Margin="0,0,10,0">
                    <Image Source="shield_person.svg" Aspect="AspectFit" />
                </Border>

                <Label Grid.Column="1" VerticalOptions="Center" FontSize="30" FontAttributes="Bold" CharacterSpacing="0.5">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Heimdall " TextColor="#F8FAFC" />
                            <Span Text="AI" TextColor="#3B82F6" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Border Grid.Column="2" BackgroundColor="#0F172A" StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#1E293B" WidthRequest="44" HeightRequest="44" HorizontalOptions="End" VerticalOptions="Center">
                    <ImageButton Source="settings.svg" Clicked="OnSettingsClicked" WidthRequest="18" HeightRequest="18" BackgroundColor="Transparent" Opacity="0.9" />
                </Border>
            </Grid>

            <Label Text="Historique des alertes" TextColor="White" FontSize="28" FontAttributes="Bold" />
            <Label Text="Les alertes précédentes apparaissent ici dès qu'une nouvelle alerte active est reçue." TextColor="#94A3B8" FontSize="12" />

            <HorizontalStackLayout Spacing="10" Margin="0,4,0,2">
                <Border BackgroundColor="#22B6F6" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,6">
                    <Label Text="Today" TextColor="#041529" FontAttributes="Bold" FontSize="12" />
                </Border>
                <Border BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="14,6">
                    <Label Text="Yesterday" TextColor="#CBD5E1" FontAttributes="Bold" FontSize="12" />
                </Border>
                <Border BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="14,6">
                    <Label Text="Last 7 Days" TextColor="#CBD5E1" FontAttributes="Bold" FontSize="12" />
                </Border>
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,0,0,2">
                <Label Text="Sévérité:" VerticalOptions="Center" TextColor="#94A3B8" FontSize="14" />
                <Border Grid.Column="1" BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,4">
                    <Picker Title="Toutes les sévérités"
                            TextColor="#CBD5E1"
                            TitleColor="#94A3B8"
                            SelectedIndex="0">
                        <Picker.Items>
                            <x:String>Toutes les sévérités</x:String>
                            <x:String>Alert</x:String>
                            <x:String>Info</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>
            </Grid>

            <CollectionView ItemsSource="{Binding ListeAlertesHistoriques}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Alertes">
                        <Border StrokeShape="RoundRectangle 16" Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#1C2A42" Margin="0,2,0,12" Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoriqueViewModels}}, Path=AlerteTappedCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="4,Auto,*,Auto" Padding="0">
                                <Border Grid.Column="0" BackgroundColor="{Binding CouleurHistoriqueAccent}" StrokeThickness="0" StrokeShape="RoundRectangle 8" />

                                <Border Grid.Column="1" Margin="12,14,10,14" WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="{Binding CouleurHistoriqueIconeFond}" StrokeShape="RoundRectangle 12" Padding="10">
                                    <Image Source="{Binding IconeHistorique}" Aspect="AspectFit" />
                                </Border>

                                <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center" Margin="0,10,0,10">
                                    <Label Text="{Binding Titre}" TextColor="#F8FAFC" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding ResumeHistorique}" TextColor="#94A3B8" FontSize="13" />
                                    <Label Text="{Binding Description}" TextColor="#64748B" FontSize="12" LineBreakMode="TailTruncation" MaxLines="1" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="3" Spacing="8" VerticalOptions="Center" Margin="10,0,12,0">
                                    <Border StrokeThickness="0" BackgroundColor="{Binding CouleurHistoriqueBadge}" StrokeShape="RoundRectangle 10" Padding="10,4" HorizontalOptions="End">
                                        <Label Text="{Binding TypeHistoriqueTexte}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                                    </Border>
                                    <Label Text="Listen" TextColor="#22B6F6" FontSize="14" FontAttributes="Bold" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,50,0,0">
                        <Image Source="history.svg" WidthRequest="40" HeightRequest="40" HorizontalOptions="Center" Opacity="0.8" />
                        <Label Text="Aucune alerte dans l'historique" TextColor="#94A3B8" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
