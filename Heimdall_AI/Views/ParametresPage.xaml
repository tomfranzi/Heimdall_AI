<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             x:Class="Heimdall_AI.Views.ParametresPage"
             BackgroundColor="#020817"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,30" Spacing="18">

            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#0B2A5E" Padding="11" Margin="0,0,10,0">
                    <Image Source="shield_person.svg" Aspect="AspectFit" />
                </Border>

                <Label Grid.Column="1" VerticalOptions="Center" FontSize="30" FontAttributes="Bold" CharacterSpacing="0.5">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Heimdall " TextColor="#F8FAFC" />
                            <Span Text="AI" TextColor="#3B82F6" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Border Grid.Column="2" BackgroundColor="#0F172A" StrokeShape="RoundRectangle 22" StrokeThickness="1" Stroke="#1E293B" WidthRequest="44" HeightRequest="44" HorizontalOptions="End" VerticalOptions="Center">
                    <ImageButton Source="settings.svg" Clicked="OnSettingsClicked" WidthRequest="18" HeightRequest="18" BackgroundColor="Transparent" Opacity="0.9" />
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="SENSIBILITÉ MICRO" TextColor="#64748B" FontSize="12" FontAttributes="Bold" CharacterSpacing="1.2" />
                    <Label Grid.Column="1" Text="{Binding SensibiliteMicro, StringFormat='{0:F0}%'}" TextColor="#60A5FA" FontSize="22" FontAttributes="Bold" />
                </Grid>

                <Label Text="Réglage de sensibilité" TextColor="White" FontSize="28" FontAttributes="Bold" />

                <Border StrokeShape="RoundRectangle 14" Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#0F172A" Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Slider Minimum="0" Maximum="100" Value="{Binding SensibiliteMicro}" MinimumTrackColor="#3B82F6" MaximumTrackColor="#334155" ThumbColor="#60A5FA">
                            <Slider.Behaviors>
                                <toolkit:EventToCommandBehavior EventName="DragCompleted" Command="{Binding PublierSensibiliteCommand}" />
                            </Slider.Behaviors>
                        </Slider>
                        <Grid ColumnDefinitions="*,*,*">
                            <Label Text="MIN" TextColor="#64748B" FontSize="10" />
                            <Label Grid.Column="1" Text="NORMAL" TextColor="#64748B" HorizontalOptions="Center" FontSize="10" />
                            <Label Grid.Column="2" Text="MAX" TextColor="#64748B" HorizontalOptions="End" FontSize="10" />
                        </Grid>
                        <Label Text="La sensibilité est appliquée dès que vous relâchez la barre." TextColor="#94A3B8" FontSize="12" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="CATÉGORIES SONORES" TextColor="#64748B" FontSize="12" FontAttributes="Bold" CharacterSpacing="1.2" />

                <Border StrokeShape="RoundRectangle 14" Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#0F172A" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2C1730" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="person.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Parole" TextColor="White" FontSize="16" />
                                <Label Text="Voix et conversations" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectSpeech}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#302117" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="home.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Toc à la porte" TextColor="White" FontSize="16" />
                                <Label Text="Détection de coups à la porte" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectKnock}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E2A13" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="detector_alarm.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Alarme" TextColor="White" FontSize="16" />
                                <Label Text="Sirène et signaux d'alarme" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectAlarm}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E1631" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="home.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Porte" TextColor="White" FontSize="16" />
                                <Label Text="Ouverture/fermeture de porte" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectDoor}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#103129" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="analytics.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Mécanique" TextColor="White" FontSize="16" />
                                <Label Text="Bruits moteur, machine" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectMechanic}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#103129" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="refresh.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Ventilateur" TextColor="White" FontSize="16" />
                                <Label Text="Bruit continu de ventilation" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectFan}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E2A13" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="bolt.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Frappe légère" TextColor="White" FontSize="16" />
                                <Label Text="Petits chocs secs" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectTap}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E2A13" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="bolt.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Coup" TextColor="White" FontSize="16" />
                                <Label Text="Impact sur une surface" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectCoup}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E1631" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="brand_awareness.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Cri aigu" TextColor="White" FontSize="16" />
                                <Label Text="Cri aigu" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectScream}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E1631" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="pets.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Cri fort" TextColor="White" FontSize="16" />
                                <Label Text="Cri fort" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectShout}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E1631" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="brand_awareness.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Hurlement" TextColor="White" FontSize="16" />
                                <Label Text="Hurlement" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectYell}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2C1730" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="broken_image.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Verre" TextColor="White" FontSize="16" />
                                <Label Text="Son de verre" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectGlass}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2C1730" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="broken_image.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Bris" TextColor="White" FontSize="16" />
                                <Label Text="Bris violent" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectShatter}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#2E1631" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="child_care.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Pleurs, sanglots" TextColor="White" FontSize="16" />
                                <Label Text="Pleurs et sanglots" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectCryingSobbing}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#103129" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="pets.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Animaux domestiques" TextColor="White" FontSize="16" />
                                <Label Text="Animaux domestiques" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectDomesticAnimalsPets}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" />

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                            <Border Grid.Column="0" BackgroundColor="#103129" StrokeThickness="0" StrokeShape="RoundRectangle 9" WidthRequest="34" HeightRequest="34" Padding="8" Margin="0,0,10,0">
                                <Image Source="check_box.svg" Aspect="AspectFit" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                <Label Text="Clic" TextColor="White" FontSize="16" />
                                <Label Text="Clic sec" TextColor="#94A3B8" FontSize="11" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding DetectClick}" OnColor="#3B82F6" ThumbColor="White" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="COMPTE" TextColor="#64748B" FontSize="12" FontAttributes="Bold" CharacterSpacing="1.2" />

                <Border StrokeShape="RoundRectangle 14" Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#0F172A" Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Nom actuel" TextColor="#94A3B8" FontSize="12" />
                        <Entry Text="{Binding NomUtilisateurCompte}" Placeholder="Nom utilisateur" TextColor="#F8FAFC" PlaceholderColor="#64748B" IsReadOnly="True" />

                        <Label Text="Nouveau nom" TextColor="#94A3B8" FontSize="12" />
                        <Entry Text="{Binding NouveauNomUtilisateur}" Placeholder="Nouveau nom utilisateur" TextColor="#F8FAFC" PlaceholderColor="#64748B" />

                        <Label Text="Nouveau mot de passe" TextColor="#94A3B8" FontSize="12" />
                        <Entry Text="{Binding NouveauMotDePasse}" Placeholder="Nouveau mot de passe" IsPassword="True" TextColor="#F8FAFC" PlaceholderColor="#64748B" />

                        <Button Text="Mettre à jour le compte"
                                Command="{Binding MettreAJourCompteCommand}"
                                BackgroundColor="#3B82F6"
                                TextColor="#F8FAFC"
                                FontAttributes="Bold"
                                CornerRadius="12" />

                        <Button Text="Se déconnecter"
                                Command="{Binding DeconnexionCommand}"
                                BackgroundColor="#1E293B"
                                TextColor="#F8FAFC"
                                FontAttributes="Bold"
                                CornerRadius="12" />

                        <Button Text="Supprimer le compte"
                                Command="{Binding SupprimerCompteCommand}"
                                BackgroundColor="#7F1D1D"
                                TextColor="#F8FAFC"
                                FontAttributes="Bold"
                                CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
