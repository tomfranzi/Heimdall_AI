<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Heimdall_AI.Views.LoginPage"
             BackgroundColor="#020817"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,24" Spacing="16">

            <Label Text="CONNEXION"
                   TextColor="#F8FAFC"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   FontSize="34" />

            <Border Stroke="#1E293B"
                    StrokeThickness="1"
                    BackgroundColor="#0B1F3F"
                    StrokeShape="RoundRectangle 22"
                    Padding="22"
                    Margin="0,4,0,0">
                <Border.Shadow>
                    <Shadow Brush="#4D3B82F6" Radius="20" Opacity="0.8" Offset="0,8" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="8">
                    <Image Source="shield_person.svg"
                           WidthRequest="100"
                           HeightRequest="100"
                           HorizontalOptions="Center" />

                    <Label HorizontalOptions="Center" FontSize="22" FontAttributes="Bold" CharacterSpacing="0.8">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="HEIMDALL " TextColor="#F8FAFC" />
                                <Span Text="AI" TextColor="#3B82F6" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Text="Accès sécurisé à votre gardien IA"
                           TextColor="#94A3B8"
                           FontSize="13"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="8" Margin="0,10,0,0">
                <Label Text="Nom utilisateur"
                       TextColor="#E2E8F0"
                       FontSize="14"
                       FontAttributes="Bold" />

                <Border Stroke="#1E293B"
                        StrokeThickness="1"
                        BackgroundColor="#111827"
                        StrokeShape="RoundRectangle 14"
                        Padding="12,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="✉"
                               TextColor="#3B82F6"
                               FontSize="18"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               x:Name="UsernameEntry"
                               Placeholder="tom"
                               PlaceholderColor="#64748B"
                               TextColor="#F8FAFC"
                               IsTextPredictionEnabled="False"
                               IsSpellCheckEnabled="False" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Mot de passe"
                       TextColor="#E2E8F0"
                       FontSize="14"
                       FontAttributes="Bold" />

                <Border Stroke="#1E293B"
                        StrokeThickness="1"
                        BackgroundColor="#111827"
                        StrokeShape="RoundRectangle 14"
                        Padding="12,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🔒"
                               TextColor="#3B82F6"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               x:Name="PasswordEntry"
                               Placeholder="••••••••"
                               PlaceholderColor="#64748B"
                               TextColor="#F8FAFC"
                               IsPassword="True"
                               IsTextPredictionEnabled="False"
                               IsSpellCheckEnabled="False" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <Label Text="Mot de passe oublié ?"
                   TextColor="#3B82F6"
                   FontSize="13"
                   HorizontalOptions="End" />

            <Button Text="Se connecter"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#3B82F6"
                    TextColor="#F8FAFC"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="54"
                    Margin="0,4,0,0" />

            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,0">
                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#1E293B" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="OU BIOMÉTRIE" TextColor="#64748B" FontSize="12" Margin="10,0" />
                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#1E293B" VerticalOptions="Center" />
            </Grid>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Border Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#0F172A" StrokeShape="RoundRectangle 12" Padding="12,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="😎" HorizontalOptions="Center" FontSize="18" />
                        <Label Text="FACE ID" TextColor="#94A3B8" FontSize="10" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border Stroke="#1E293B" StrokeThickness="1" BackgroundColor="#0F172A" StrokeShape="RoundRectangle 12" Padding="12,8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🆔" HorizontalOptions="Center" FontSize="18" />
                        <Label Text="TOUCH ID" TextColor="#94A3B8" FontSize="10" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,6,0,0">
                <Label Text="Pas encore de compte ?" TextColor="#94A3B8" FontSize="13" />
                <Button Text="Créer un compte"
                        Clicked="OnCreateAccountClicked"
                        TextColor="#3B82F6"
                        FontAttributes="Bold"
                        FontSize="13"
                        Padding="0"
                        BackgroundColor="Transparent" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
