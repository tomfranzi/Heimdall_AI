<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Heimdall_AI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Heimdall_AI.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#0F172A"
    Shell.TabBarUnselectedColor="#64748B"
    Shell.TabBarTitleColor="#3B82F6">

    <TabBar>
        <Tab Title="Accueil">
            <ShellContent Route="SupervisionPage" ContentTemplate="{DataTemplate views:SupervisionPage}" />
        </Tab>

        <Tab Title="Alertes">
            <ShellContent Route="AlertesPage" ContentTemplate="{DataTemplate views:AlertesPage}" />
        </Tab>
    </TabBar>

</Shell>